{
  "name": "3d-runner-coin-game",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "electron": "npm run build && electron .",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/package-win.ps1",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run"
  },
  "dependencies": {
    "three": "^0.166.1"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.multimedia.neon-coin-runner",
    "productName": "霓虹金币跑酷",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-免安装版-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-免安装版-${version}.${ext}"
    }
  }
}
